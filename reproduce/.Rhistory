library(dplyr)
## Part D - 0.5 pts
ggplot(data = ioct, aes(x = sex, y = height)) + geom_boxplot()
ioct = read.csv("https://data.scorenetwork.org/data/ioct_west_point.csv")
ggplot(data = ioct, aes(x = sex, y = height)) + geom_boxplot()
## They are associated,
ggplot(data = ioct, aes(x = sex, y = IOCT_Time)) + geom_boxplot()
q1_model2 = lm(IOCT_Time ~ height + sex, data = ioct)
coef(q1_model2)
## PART B - 0.5 pts
lm(finish_net_sec ~ age_group, data = marathon)
marathon = read.csv("https://data.scorenetwork.org/data/boston_marathon_2023.csv")
## Part A - 0.5 pts
table(marathon$age_group)
# The distribution in concentrated in the younger age groups, with comparatively fewer older finishers
## PART B - 0.5 pts
lm(finish_net_sec ~ age_group, data = marathon)
ggplot(data = marathon, aes(x = half_time_sec, y = finish_net_sec)) + geom_point()
## PART E  - 0.75 pts
lm(finish_net_sec ~ half_time_sec, data = marathon)
## PART F - 0.5 pts
lm(finish_net_sec ~ half_time_sec + age_group, data = marathon)
