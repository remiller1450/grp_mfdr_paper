library(reshape2)
library(ggplot2)
library(knitr)
library(kableExtra)
library(dplyr)
library(datasets)
library(gridExtra)
shots = read.csv("C:\\Users\\millerry\\Downloads\\shot_logs.csv") %>% mutate(made_binary = ifelse(SHOT_RESULT == "made", 1, 0))
shots_sc = shots %>% filter(player_name == "stephen curry")
table(shots_sc$DRIBBLES, shots_sc$made_binary)
table(shots_sc$DRIBBLES > 0, shots_sc$made_binary)
knitr::opts_chunk$set(echo = TRUE, message = FALSE, warning = FALSE, fig.height = 2.5)
library(knitr)
library(ggplot2)
library(dplyr)
wells = read.csv("https://remiller1450.github.io/data/Wells.csv") %>%
mutate(switch_binary = ifelse(switch == "yes", 1, 0))
ggplot(data = wells, aes(x = education, y = switch)) + geom_boxplot()
ggplot(data = wells, aes(x = arsenic, y = switch)) + geom_boxplot()
ggplot(data = wells, aes(x = distance, y = switch)) + geom_boxplot()
m0 = glm(switch_binary ~ 1, data = wells, family = "binomial")
m1 = glm(switch_binary ~ arsenic, data = wells, family = "binomial")
m2 = glm(switch_binary ~ arsenic + distance, data = wells, family = "binomial")
m3 = glm(switch_binary ~ arsenic + distance + education, data = wells, family = "binomial")
m4 = glm(switch_binary ~ arsenic + distance + education + association, data = wells, family = "binomial")
lrtest(m0, m1)
m1
m2
m3
summary(m2)
summary(wells)
m4 = glm(switch_binary ~ arsenic + distance  + association, data = wells, family = "binomial")
m4
summary(m4)
